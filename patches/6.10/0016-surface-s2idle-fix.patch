+MODULE_AUTHOR("Surface Linux Debug");
+MODULE_DESCRIPTION("Fix s2idle/hibernate death sleep on Surface Laptop 5 (v5.6)");
+MODULE_VERSION("5.6");
+MODULE_ALIAS("dmi:*:svnMicrosoftCorporation:pnSurfaceLaptop5:*");
