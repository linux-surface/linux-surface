+		.keybit = { [BIT_WORD(KEY_POWER)] = BIT_MASK(KEY_POWER) },
+	},
+	{ },
+};
+
+MODULE_DEVICE_TABLE(input, pwr_ids);
+
+static struct input_handler pwr_handler = {
+	.event      = pwr_event,
+	.connect    = pwr_connect,
+	.disconnect = pwr_disconnect,
